# ============================================================
# .env.example  —  kopirajte u  .env  i popunite vrijednosti
# ============================================================

# --- OpenWeatherMap (besplatno: openweathermap.org/api) ---
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# --- NewsAPI (besplatno: newsapi.org) ---
NEWS_API_KEY=your_newsapi_key_here

# --- Gmail SMTP ---
# Koristite "App Password" (ne vašu lozinku!):
# Google nalog → Sigurnost → 2FA → App Passwords
GMAIL_USER=acatovic@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# --- Telegram Bot (alternativa) ---
# Kreirajte bota putem @BotFather, dobijete TOKEN
# Chat ID dobijate putem: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Destinacijska email adresa ---
RECIPIENT_EMAIL=acatovic@gmail.com

# --- Opcije isporuke: "email", "telegram" ili "both" ---
DELIVERY_METHOD=both
